# ═══════════════════════════════════════════════════════════════
# Phoenix ML — Docker Environment Variables
# This file is .gitignored. Copy from .env.example and adjust.
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL (App Database) ────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=phoenix

# ─── Redis ────────────────────────────────────────────────────
USE_REDIS=true
REDIS_URL=redis://redis:6379

# ─── Kafka ────────────────────────────────────────────────────
KAFKA_URL=kafka:9092

# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ─── Jaeger ───────────────────────────────────────────────────
JAEGER_ENDPOINT=http://jaeger:4317

# ─── Grafana ──────────────────────────────────────────────────
GF_ADMIN_PASSWORD=admin

# ─── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Airflow ──────────────────────────────────────────────────
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ─── Self-Healing Pipeline ────────────────────────────────────
ALERT_WEBHOOK_URL=

# ─── Model Config (Framework) ────────────────────────────────
# Set this to your model's ID. Must match a file in model_configs/
DEFAULT_MODEL_ID=credit-risk
